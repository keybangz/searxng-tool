[Unit]
Description=SearXNG self-hosted search (MCP backend)
Documentation=https://github.com/searxng/searxng-docker

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/mnt/extra_ssd/Github/searxng-tool
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=60

[Install]
WantedBy=default.target
